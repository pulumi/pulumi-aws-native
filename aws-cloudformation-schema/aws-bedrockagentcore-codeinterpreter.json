{
  "typeName" : "AWS::BedrockAgentCore::CodeInterpreter",
  "description" : "Definition of AWS::BedrockAgentCore::CodeInterpreter Resource Type. This is a read-only resource representing the AWS-managed default code interpreter (aws.codeinterpreter.v1).",
  "properties" : {
    "CodeInterpreterArn" : {
      "type" : "string",
      "description" : "The Amazon Resource Name (ARN) of the code interpreter.",
      "pattern" : "^arn:[a-z0-9-]+:bedrock-agentcore:[a-z0-9-]+:(aws|[0-9]{12}):code-interpreter/aws\\.codeinterpreter\\.v1$"
    },
    "CodeInterpreterId" : {
      "type" : "string",
      "description" : "The unique identifier of the code interpreter.",
      "pattern" : "^aws\\.codeinterpreter\\.v1$"
    },
    "Status" : {
      "type" : "string",
      "description" : "The current status of the code interpreter.",
      "enum" : [ "CREATING", "CREATE_FAILED", "READY", "DELETING", "DELETE_FAILED", "DELETED" ]
    }
  },
  "readOnlyProperties" : [ "/properties/CodeInterpreterArn", "/properties/CodeInterpreterId", "/properties/Status" ],
  "primaryIdentifier" : [ "/properties/CodeInterpreterArn" ],
  "additionalIdentifiers" : [ [ "/properties/CodeInterpreterId" ] ],
  "tagging" : {
    "taggable" : false
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "bedrock-agentcore:GetCodeInterpreter" ]
    },
    "list" : {
      "permissions" : [ "bedrock-agentcore:ListCodeInterpreters" ]
    }
  },
  "additionalProperties" : false
}