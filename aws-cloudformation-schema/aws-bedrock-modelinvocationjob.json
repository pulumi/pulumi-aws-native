      "description" : "The configuration of the Virtual Private Cloud (VPC) for the data in the batch inference job."
    },
    "TimeoutDurationInHours" : {
      "type" : "integer",
      "description" : "The number of hours after which to force the batch inference job to time out.",
      "minimum" : 24,
      "maximum" : 168
    },
    "Status" : {
      "$ref" : "#/definitions/ModelInvocationJobStatus"
    },
    "SubmitTime" : {
      "type" : "string",
      "description" : "The time at which the batch inference job was submitted.",
      "format" : "date-time"
    },
    "LastModifiedTime" : {
      "type" : "string",
      "description" : "The time at which the batch inference job was last modified.",
      "format" : "date-time"
    },
    "JobExpirationTime" : {
      "type" : "string",
      "description" : "The time at which the batch inference job times or timed out.",
      "format" : "date-time"
    },
    "Tags" : {
      "type" : "array",
      "description" : "Any tags associated with the batch inference job.",
      "items" : {
        "$ref" : "#/definitions/Tag"
      },
      "minItems" : 0,
      "maxItems" : 200,
      "insertionOrder" : false
    }
  },
  "additionalProperties" : false,
  "readOnlyProperties" : [ "/properties/JobArn", "/properties/JobName", "/properties/ModelId", "/properties/RoleArn", "/properties/InputDataConfig", "/properties/OutputDataConfig", "/properties/VpcConfig", "/properties/TimeoutDurationInHours", "/properties/Status", "/properties/SubmitTime", "/properties/LastModifiedTime", "/properties/JobExpirationTime", "/properties/Tags" ],
  "primaryIdentifier" : [ "/properties/JobArn" ],
  "tagging" : {
    "taggable" : true,
    "tagOnCreate" : false,
    "tagUpdatable" : false,
    "cloudFormationSystemTags" : false,
    "tagProperty" : "/properties/Tags",
    "permissions" : [ "bedrock:ListTagsForResource" ]
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "bedrock:GetModelInvocationJob", "bedrock:ListTagsForResource" ]
    },
    "list" : {
      "permissions" : [ "bedrock:ListModelInvocationJobs" ]
    }
  }
}