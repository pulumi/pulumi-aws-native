{
  "typeName" : "AWS::BedrockAgentCore::Browser",
  "description" : "Definition of AWS::BedrockAgentCore::Browser Resource Type. This is a read-only resource representing the default service-managed browser.",
  "properties" : {
    "BrowserArn" : {
      "type" : "string",
      "description" : "The Amazon Resource Name (ARN) of the browser.",
      "pattern" : "^arn:[a-z0-9-]+:bedrock-agentcore:[a-z0-9-]+:(aws|[0-9]{12}):browser/aws\\.browser\\.v1$"
    },
    "BrowserId" : {
      "type" : "string",
      "description" : "The unique identifier of the browser.",
      "pattern" : "^aws\\.browser\\.v1$"
    },
    "Name" : {
      "type" : "string",
      "description" : "The name of the browser."
    },
    "Status" : {
      "type" : "string",
      "description" : "The current status of the browser.",
      "enum" : [ "READY" ]
    }
  },
  "readOnlyProperties" : [ "/properties/BrowserArn", "/properties/BrowserId", "/properties/Name", "/properties/Status" ],
  "primaryIdentifier" : [ "/properties/BrowserArn" ],
  "additionalIdentifiers" : [ [ "/properties/BrowserId" ] ],
  "tagging" : {
    "taggable" : false
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "bedrock-agentcore:GetBrowser" ]
    },
    "list" : {
      "permissions" : [ "bedrock-agentcore:ListBrowsers" ]
    }
  },
  "additionalProperties" : false
}